{
  "name": "yourpc",
  "version": "0.1.0",
  "private": true,
  "packageManager": "npm@11.11.1",
  "engines": {
    "node": ">=22 <23"
  },
  "scripts": {
    "dev": "next dev",
    "build": "next build --webpack",
    "start": "next start",
    "lint": "eslint",
    "typecheck": "tsc --noEmit",
    "test": "tsx --test tests/*.test.ts",
    "check": "npm run lint && npm run typecheck && npm run test",
    "launch:check": "tsx scripts/launch-check.ts",
    "db:reconcile-order-stock": "tsx scripts/reconcile-order-stock.ts",
    "assets:optimize": "node scripts/optimize-public-images.mjs",
    "prod": "npm run build && npm run start",
    "db:seed:products": "tsx lib/seed-products.ts",
    "db:seed:products:reset": "tsx lib/seed-products.ts --reset"
  },
  "dependencies": {
    "@tiptap/react": "^3.26.0",
    "@tiptap/starter-kit": "^3.26.0",
    "@vercel/analytics": "^2.0.1",
    "@vercel/speed-insights": "^2.0.0",
    "bcryptjs": "^2.4.3",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "date-fns": "^4.1.0",
    "embla-carousel-react": "^8.1.8",
    "lucide-react": "^0.577.0",
    "mongoose": "^9.3.1",
    "next": "^16.2.7",
    "next-auth": "^5.0.0-beta.30",
    "next-cloudinary": "^6.8.2",
    "next-themes": "^0.4.6",
    "radix-ui": "^1.4.3",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "resend": "^6.12.4",
    "sanitize-html": "^2.17.4",
    "shadcn": "^4.0.8",
    "slugify": "^1.6.8",
    "sonner": "^2.0.7",
    "swr": "^2.4.1",
    "tailwind-merge": "^3.5.0",
    "tw-animate-css": "^1.4.0",
    "vaul": "^1.1.2",
    "yet-another-react-lightbox": "^3.32.0",
    "zustand": "^5.0.12"
